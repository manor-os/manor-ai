# Manor AI Configuration
# Copy this to .env and fill in your values

# ── LLM ──
# OSS model calls are BYOK-only. Configure native provider keys in Settings.
# Default model (override per user/entity in Settings)
LLM_MODEL=anthropic/claude-sonnet-4

# ── Database ──
DATABASE_URL=postgresql+asyncpg://manor:manor_secret@postgres:5432/manor
# Sync URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://manor:manor_secret@postgres:5432/manor

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Single-server emergency controls ──
# OSS-safe defaults stay conservative. Cloud production can override these in
# .env or docker-compose.cloud.yml after measuring CPU, p95, and DB connections.
API_WORKERS=1
API_LIMIT_CONCURRENCY=120
API_BACKLOG=256
API_TIMEOUT_KEEP_ALIVE=5

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2
DATABASE_POOL_TIMEOUT=10
DATABASE_POOL_RECYCLE=1800

# Redis service memory guard. Cloud suggestion: 512mb + allkeys-lru.
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

# Global/chat limiters are opt-in. To enable shared limits across API workers:
# RATE_LIMIT_ENABLED=true
# CHAT_RATE_LIMIT_ENABLED=true
# REDIS_RATE_LIMIT_ENABLED=true
# CHAT_RATE_LIMIT_REQUESTS=10
# API_RATE_LIMIT_REQUESTS=180
RATE_LIMIT_ENABLED=false
CHAT_RATE_LIMIT_ENABLED=false
REDIS_RATE_LIMIT_ENABLED=false
CHAT_RATE_LIMIT_REQUESTS=30
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_REQUESTS=200
API_RATE_LIMIT_WINDOW_SECONDS=60

# Emergency degraded mode. When DEGRADED_MODE=true, high-cost routes return
# 503 with code=degraded_mode; health/config/login/basic reads keep working.
DEGRADED_MODE=false
DEGRADED_DISABLE_CHAT_STREAM=true
DEGRADED_DISABLE_SANDBOX=true
DEGRADED_DISABLE_MEDIA_GENERATION=true
DEGRADED_DISABLE_LARGE_UPLOADS=true

# ── Storage ──
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manor

# ── JuiceFS (distributed file storage on MinIO) ──
# JuiceFS uses Redis for metadata and MinIO for data blocks.
# The juicefs service in docker-compose handles format + mount automatically.
MANOR_FS_ENABLED=true
MANOR_FS_ROOT=/mnt/manor
JUICEFS_META_URL=redis://redis:6379/1
JUICEFS_STORAGE=minio
JUICEFS_BUCKET=http://minio:9000/manor
JUICEFS_ACCESS_KEY=minioadmin
JUICEFS_SECRET_KEY=minioadmin

# ── Sandbox ──
SANDBOX_SERVICE_URL=http://sandbox:8000
SHELL_SANDBOX_ENABLED=true

# ── Auth ──
JWT_SECRET_KEY=change-this-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── OAuth (Google SSO) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Drive (Picker API for Knowledge page) ──
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Google Picker API" and "Google Drive API" in your project
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_DRIVE_API_KEY=

# ── Email (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_STARTTLS=true
EMAIL_ENABLED=false


# ── Web Search (agent tool) ──
# Engine: "serper" or "tavily"
SEARCH_ENGINE=serper
SEARCH_API_KEY=

# ── Live market data (generated Dashboard modules) ──
FINNHUB_API_KEY=

# ── Deployment mode ──
# "oss" = self-hosted mode
DEPLOYMENT_MODE=oss


VAULT_TOKEN=
VAULT_TRANSIT_KEY=manor-keys

# ── Channel integrations ──
# Public base URL the providers' servers can reach this deployment at.
# Must be https:// in production. Used to build webhook + OAuth callback URLs.
# Also required for video generation from local/Knowledge reference images:
# Manor signs /api/v1/fs/public/{token} URLs that video providers fetch.
# In local dev, text-to-video works without HTTPS; image-to-video needs a
# public HTTPS tunnel or an already public https:// reference image URL.
PUBLIC_BASE_URL=http://localhost:8010

# Public web URL. The default Docker compose web service listens on 18080 and
# proxies /api to the API container.
APP_URL=http://localhost:18080


# Telegram inbound mode: webhook | polling | auto (default).
# - webhook: integration save registers a Telegram webhook; needs HTTPS
# - polling: async getUpdates loop in the API process; no public URL needed
# - auto:    webhook when PUBLIC_BASE_URL is https, else polling
TELEGRAM_MODE=auto

# OAuth apps — register at each provider's developer portal, set the
# callback URL to {PUBLIC_BASE_URL}/api/v1/integrations/oauth/{server_key}/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# Microsoft 365 (one Azure AD App Registration powers Outlook +
# OneDrive + MS Calendar + MS Teams + MS Excel).
# Get from https://portal.azure.com → Azure Active Directory →
# App registrations → New registration → Web platform.
# Set redirect URI to {PUBLIC_BASE_URL}/api/v1/integrations/oauth/outlook/callback
# (or one per server_key; they all share the same client_id/secret).
# Required Microsoft Graph permissions (delegated):
#   Mail.Read, Mail.ReadWrite, Mail.Send,
#   Files.ReadWrite, Files.ReadWrite.All,
#   Calendars.ReadWrite, MailboxSettings.Read,
#   Team.ReadBasic.All, Channel.ReadBasic.All,
#   ChannelMessage.Read.All, ChannelMessage.Send,
#   Chat.ReadWrite, OnlineMeetings.ReadWrite, Presence.ReadWrite,
#   User.Read, offline_access
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Tenant: 'common' (default — accepts work/school + personal accounts),
# 'organizations' (work/school only), 'consumers' (MSA only), or a
# specific Azure AD tenant GUID for single-tenant deployments.
MS_TENANT=common

# Discord (OAuth client + bot + interactions signature)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=        # ed25519 public key, hex — for interaction signature verify
DISCORD_BOT_TOKEN=         # required if the bot sends messages

# Twilio (SMS + Voice + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Voice streaming providers (Twilio Media Streams)
DEEPGRAM_API_KEY=          # streaming STT
OPENAI_API_KEY=            # TTS (reused for /audio/speech)

# ── Nango (200+ SaaS OAuth aggregator) ──
# Start the bundled Nango server with:
#   docker compose --profile nango up -d nango-server
# Then visit http://localhost:3003, set the admin password, and
# Settings → copy the "Secret Key" into NANGO_SECRET_KEY below.
# Once set, every Integration card on /integrations whose server_key
# matches a Nango "provider config key" will show a Connect button
# that opens Nango's OAuth popup. Leave empty to disable Nango.
NANGO_BASE_URL=http://nango-server:3003
# Public hostname users see for OAuth callbacks + SaaS webhooks.
# Local dev: leave empty (Nango uses redirectmeto.com auto-forward).
# Prod: set to https://nango.<your-domain> — must match a DNS record
# pointing to your server, and Caddy must be running (--profile prod).
NANGO_PUBLIC_URL=
NANGO_SECRET_KEY=
NANGO_PUBLIC_KEY=
# Webhook signing secret. Generate any random 32+ char string —
# Manor's startup hook will write the same value into Nango's
# environment settings so its outbound webhooks are signed with it.
# Verified at /api/v1/nango/webhook on receive.
NANGO_WEBHOOK_SECRET=
# Public URL Nango should POST webhooks to. Defaults to the docker
# compose service URL (http://api:8000/api/v1/nango/webhook), which
# works for local dev. Override for production with your public host.
NANGO_WEBHOOK_URL=

# ── Nango platforms (auto-bootstrapped on startup) ──
# For every Nango-aggregated platform you want available, add the
# pair below. On API startup these get pushed into Nango's admin DB
# via its API — no need to click around in the Nango admin UI.
#
# Pattern:  NANGO_PROVIDER_<PROVIDER>_CLIENT_ID
#           NANGO_PROVIDER_<PROVIDER>_CLIENT_SECRET
#           NANGO_PROVIDER_<PROVIDER>_SCOPES   (optional, space-separated)
#           NANGO_PROVIDER_<PROVIDER>_KEY      (optional, defaults to <PROVIDER>)
#           NANGO_PROVIDER_<PROVIDER>_PROVIDER (optional, defaults to <PROVIDER>)
#
# Example — HubSpot:
# NANGO_PROVIDER_HUBSPOT_CLIENT_ID=
# NANGO_PROVIDER_HUBSPOT_CLIENT_SECRET=
# NANGO_PROVIDER_HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.contacts.write oauth
#
# Where to get OAuth credentials per platform:
#   HubSpot   → https://app.hubspot.com/developer/ → Apps
#   Linear    → Linear Settings → API → OAuth applications
#   Notion    → https://www.notion.so/my-integrations
#   Salesforce → Setup → Apps → App Manager → New Connected App
#   Stripe    → https://dashboard.stripe.com/apps-oauth
#   Shopify   → https://partners.shopify.com → Apps
#
# Redirect URI to enter at the platform's developer portal:
#   ${NANGO_PUBLIC_URL}/oauth/callback
# (e.g. http://localhost:3003/oauth/callback in local dev)

# ── Integration preview flag ──
# Manor ships a few integrations as "Coming Soon" (Facebook, Gmail,
# Google Calendar/Drive, PayPal, …) — they're functionally complete but
# gated until each provider's production review lands (Meta App Review,
# Google OAuth verification, etc.). Set this env var on dev / staging
# to surface specific providers + channels for Test User work without
# opening them to real users on prod.
#
# Comma-separated provider keys (case-insensitive), e.g.:
#   MANOR_PREVIEW_INTEGRATIONS=facebook,gmail
#   MANOR_PREVIEW_CHANNELS=facebook
# Leave empty in production until the upstream review approves the
# provider + scope set.
MANOR_PREVIEW_INTEGRATIONS=
MANOR_PREVIEW_CHANNELS=

# ── Facebook (Meta) — example provider config ──
# Get App ID / App Secret from https://developers.facebook.com →
# My Apps → your app → App settings → Basic. Add Facebook Login as a
# product, set Valid OAuth Redirect URIs to ${NANGO_PUBLIC_URL}/oauth/callback,
# and (for production) submit the listed scopes to Meta App Review.
# To unlock the Pages + Messenger surface in Manor:
# NANGO_PROVIDER_FACEBOOK_CLIENT_ID=
# NANGO_PROVIDER_FACEBOOK_CLIENT_SECRET=
# NANGO_PROVIDER_FACEBOOK_SCOPES=email,public_profile,pages_show_list,pages_read_engagement,pages_manage_posts,pages_manage_engagement,pages_messaging
# To also unlock Instagram Business (PR #13's IG tools), append:
#   ,instagram_basic,instagram_content_publish,instagram_manage_comments,instagram_manage_insights
